# Murmur GCP Sandbox Configuration
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is gitignored — your real values never reach the repo.

# GCP project
GCP_PROJECT_ID=your-project-id-here
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Cloud Storage (audit log sink destination)
GCS_AUDIT_BUCKET=your-audit-bucket-name

# Cloud Run
CLOUD_RUN_SERVICE=normal-worker
CLOUD_RUN_URL=https://your-service.us-central1.run.app

# Cloud Scheduler
SCHEDULER_SA=scheduler-sa@your-project-id.iam.gserviceaccount.com
SCHEDULER_JOB=trigger-normal-worker

# Compute Engine
VM_NAME=murmur-vm
