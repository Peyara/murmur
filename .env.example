# Murmur GCP Sandbox Configuration
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is gitignored — your real values never reach the repo.

# GCP project
GCP_PROJECT_ID=your-project-id-here
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Cloud Storage (audit log sink destination)
GCS_AUDIT_BUCKET=your-audit-bucket-name

# Cloud Run (service name — URL is derived via gcloud)
CLOUD_RUN_SERVICE=normal-worker

# Service-to-SA mapping (JSON). Override for non-sandbox GCP projects.
# Default (if unset): derives from GCP_PROJECT_ID with sandbox SA naming.
# SERVICE_WORKER_MAP={"my-service": "my-sa@my-project.iam.gserviceaccount.com"}

# Compute Engine
VM_NAME=murmur-vm
